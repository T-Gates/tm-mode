[
  {
    "event": "SessionStart",
    "script": "session-start.py",
    "timeout": 30,
    "mode": "on",
    "enforcement": "advisory",
    "_timeout_unit": "seconds",
    "_timeout_note": "네트워크 훅(do_reconcile: fetch+ff/rebase) — NET_TIMEOUT(10s) 순차 호출 최악치 + 여유. 3s 면 훅 러너가 git_ops 반환 전에 죽여 sync-warning 기록까지 날린다(codex P1)."
  },
  {
    "event": "UserPromptSubmit",
    "script": "session-log-remind.py",
    "timeout": 2,
    "mode": "on",
    "enforcement": "advisory",
    "_timeout_unit": "seconds"
  },
  {
    "event": "PostToolUse",
    "match": { "action": "file_edit" },
    "script": "auto-commit.py",
    "timeout": 20,
    "fallback": "runtime",
    "enforcement": "block",
    "_timeout_unit": "seconds",
    "_timeout_note": "#45 async push: 동기 구간은 로컬 커밋까지 — push 는 detach worker 몫. 로컬 worst(codex P1 재계산) = do_commit 하위호출 4개(rev-parse/add/staged/commit) x DEFAULT_TIMEOUT 2s = 8s, index.lock 재시도 시 +1s+8s = 17s + ledger/kick 여유 = 20s. PUSH_TOTAL_BUDGET(22) 미만 유지 — 동기 push 회귀 감지선."
  },
  {
    "event": "PreToolUse",
    "match": { "mcp": { "server": "linear", "tool": "create_issue" } },
    "script": "confirm-action.py",
    "args": "teammode-linear-create-allow",
    "timeout": 2,
    "fallback": "runtime",
    "enforcement": "block",
    "strict": true,
    "_timeout_unit": "seconds"
  },
  {
    "event": "PreToolUse",
    "match": { "action": "file_edit" },
    "script": "kb-write-guard.py",
    "timeout": 2,
    "fallback": "runtime",
    "enforcement": "block",
    "strict": true,
    "mode": "on",
    "_timeout_unit": "seconds",
    "_note": "KB 쓰기 거버넌스: memory/ 직접 편집 차단. memory 동사 경유만 허용."
  }
]
