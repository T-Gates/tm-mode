[
  {
    "event": "SessionStart",
    "script": "session-start.py",
    "timeout": 30,
    "mode": "on",
    "enforcement": "advisory",
    "_timeout_unit": "seconds",
    "_timeout_note": "네트워크 훅(do_reconcile: fetch+ff/rebase) — NET_TIMEOUT(10s) 순차 호출 최악치 + 여유. 3s 면 훅 러너가 git_ops 반환 전에 죽여 sync-warning 기록까지 날린다(codex P1)."
  },
  {
    "event": "UserPromptSubmit",
    "script": "session-log-remind.py",
    "timeout": 2,
    "mode": "on",
    "enforcement": "advisory",
    "_timeout_unit": "seconds"
  },
  {
    "event": "PostToolUse",
    "match": { "action": "file_edit" },
    "script": "auto-commit.py",
    "timeout": 10,
    "fallback": "runtime",
    "enforcement": "block",
    "_timeout_unit": "seconds",
    "_timeout_note": "#45 async push: 동기 구간은 로컬 커밋까지(add/staged/commit 각 DEFAULT_TIMEOUT 2s + index.lock 1s 재시도 + ledger/kick) — push 는 detach worker 몫이라 NET_TIMEOUT 여유 불필요. 10s = 로컬 worst + 기동 여유."
  },
  {
    "event": "PreToolUse",
    "match": { "mcp": { "server": "linear", "tool": "create_issue" } },
    "script": "confirm-action.py",
    "args": "teammode-linear-create-allow",
    "timeout": 2,
    "fallback": "runtime",
    "enforcement": "block",
    "strict": true,
    "_timeout_unit": "seconds"
  },
  {
    "event": "PreToolUse",
    "match": { "action": "file_edit" },
    "script": "kb-write-guard.py",
    "timeout": 2,
    "fallback": "runtime",
    "enforcement": "block",
    "strict": true,
    "mode": "on",
    "_timeout_unit": "seconds",
    "_note": "KB 쓰기 거버넌스: memory/ 직접 편집 차단. memory 동사 경유만 허용."
  }
]
